# =========================================================================
# SOL ⇄ DecentralChain Bridge — Environment Variables
#
# Copy this file to .env and fill in the values.
# NEVER commit the .env file with secrets!
# =========================================================================

# ---------- Solana ----------
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
SOLANA_PROGRAM_ID=9yJDb6VyjDHmQC7DLADDdLFm9wxWanXRM5x9SdZ3oVkF
# PDA derived automatically from program — set for reference only
# SOLANA_VAULT_PDA=

# ---------- DecentralChain ----------
DCC_NODE_URL=https://keough-node.decentralchain.io
DCC_BRIDGE_CONTRACT=3P_BRIDGE_CONTROLLER_ADDRESS
DCC_CHAIN_ID=63
DCC_CHAIN_ID_CHAR=?
SOL_ASSET_ID=REPLACE_WITH_SOL_ASSET_ID
# Validator's DCC seed phrase — used to sign mint transactions
# CRITICAL: Keep secret! Never commit!
DCC_VALIDATOR_SEED=replace with your 15-word DCC seed phrase

# ---------- Validator ----------
VALIDATOR_NODE_ID=validator-1
VALIDATOR_PRIVATE_KEY_PATH=./data/keys/validator.key
MIN_VALIDATORS=2
MAX_VALIDATORS=5
SOLANA_CONFIRMATIONS=32
DCC_CONFIRMATIONS=10
CONSENSUS_TIMEOUT_MS=30000
REORG_PROTECTION_SLOTS=50

# ---------- Validator P2P ----------
P2P_PORT=9000
BOOTSTRAP_PEERS=
# Format: host1:port1,host2:port2

# ---------- HSM (production only) ----------
HSM_ENABLED=false
HSM_MODULE_PATH=
HSM_PIN=
HSM_SLOT=0

# ---------- API Server ----------
API_PORT=3000
ALLOWED_ORIGINS=http://localhost:5173

# ---------- Frontend ----------
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_API_URL=http://localhost:3000/api/v1

# ---------- Monitoring ----------
MONITOR_PORT=9091
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PAGERDUTY_ROUTING_KEY=
ALERT_WEBHOOK_URL=
MIN_ACTIVE_VALIDATORS=2

# ---------- Health / Metrics ----------
HEALTH_CHECK_PORT=8080
METRICS_PORT=9090

# ---------- Rate Limits ----------
MIN_DEPOSIT_LAMPORTS=1000000
MAX_DEPOSIT_LAMPORTS=10000000000
MAX_DAILY_OUTFLOW_LAMPORTS=50000000000
LARGE_WITHDRAWAL_THRESHOLD=50000000000
LARGE_WITHDRAWAL_DELAY_MS=3600000
