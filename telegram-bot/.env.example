# ─── Bot Backend ──────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ─── Master Secret ─────────────────────────────────────────────────
# Used to derive per-user custodial wallets. Keep this secret!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_SECRET=change_this_to_a_random_64_hex_char_string_and_keep_it_secret

# ─── Bridge (DCC) ──────────────────────────────────────────────────
DCC_BRIDGE_CONTRACT=3Dcw59P4kGhWxTZKN4uGQgH9iWQanfRuMBG
DCC_NODE_URL=https://mainnet-node.decentralchain.io
DCC_CHAIN_ID_CHAR=?
DCC_VALIDATOR_SEED=your_dcc_seed_phrase_here
DCC_VALIDATOR_NONCE=1
DCC_API_KEY=your_dcc_node_api_key_here

# ─── Solana ────────────────────────────────────────────────────────
SOL_RPC_URL=https://api.devnet.solana.com
SOL_PROGRAM_ID=9yJDb6VyjDHmQC7DLADDdLFm9wxWanXRM5x9SdZ3oVkF
SOL_ASSET_ID=AFpkMV8xmEf8F7n8Pk6T57ddeQCoCwmsA1aJQEtgF6gz

# ─── Storage ───────────────────────────────────────────────────────
